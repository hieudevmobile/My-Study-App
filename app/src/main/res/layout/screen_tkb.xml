<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/tkb_surface"
    android:fitsSystemWindows="true"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/tkb_header_gradient"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tkb_title"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="@color/tkb_on_primary"
            tools:text="Thời khóa biểu" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:alpha="0.92"
            android:text="@string/tkb_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="@color/tkb_on_primary" />
    </LinearLayout>

    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabCalendar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@color/tkb_surface_card"
        android:elevation="2dp"
        app:tabGravity="fill"
        app:tabIndicatorColor="@color/tkb_tab_indicator"
        app:tabIndicatorFullWidth="false"
        app:tabMode="fixed"
        app:tabRippleColor="@color/tkb_outline"
        app:tabSelectedTextColor="@color/tkb_primary"
        app:tabTextAppearance="@style/TextAppearance.Material3.LabelLarge"
        app:tabTextColor="@color/tkb_muted" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/tkb_outline" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewCalendar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

</LinearLayout>
